# Actio frontend env vars are loaded by Vite at build/dev time. Drop a
# `.env.local` next to this file with overrides; Vite picks it up
# automatically and `.env.local` is in .gitignore.

# ── Backend API base URL ───────────────────────────────────────────────
# Where the frontend looks for the Actio backend's HTTP/WS interface.
# Leave unset to use the built-in port-discovery probe (tries
# 127.0.0.1:3000 through :3009 and picks the first one answering
# `/health`). Set this only when:
#   • The backend is on a non-default host (Tauri custom shell, remote
#     dev, container forwarding).
#   • You want to bypass the discovery probe entirely.
# Format: full origin, with or without a trailing slash. Trailing
# slashes are normalized away.
# VITE_ACTIO_API_BASE_URL=http://127.0.0.1:3000
