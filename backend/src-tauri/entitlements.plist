<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Microphone access — required by cpal for ASR/dictation. -->
  <key>com.apple.security.device.audio-input</key>
  <true/>

  <!-- llama-cpp-2 may allocate JIT pages for inference kernels under Metal. -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Bundled sherpa-onnx and llama-cpp-2 dylibs are signed with their
       upstream identity, not Actio's Developer ID. Without this, dlopen()
       refuses to load them under the Hardened Runtime. -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
